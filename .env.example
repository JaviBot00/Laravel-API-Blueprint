APP_NAME="Laravel API Blueprint"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://laravel.diputacion.malaga.es

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de datos — deben coincidir con los valores en docker-compose.yml
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel_api
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# JWT — se genera automáticamente en el primer arranque (entrypoint.sh)
JWT_SECRET=
JWT_TTL=60

# Swagger
# URL pública de la API que verá la UI de Swagger en "Try it out"
# En producción: https://laravel.diputacion.malaga.es
# En desarrollo: http://localhost:8080
L5_SWAGGER_CONST_HOST=https://laravel.diputacion.malaga.es

# false en producción: Swagger solo se regenera ejecutando deploy.sh
# true en desarrollo local para comodidad
L5_SWAGGER_GENERATE_ALWAYS=false
