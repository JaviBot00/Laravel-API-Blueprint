# =============================================================================
# .gitignore — Laravel API Blueprint
# =============================================================================

# -----------------------------------------------------------------------------
# Entorno y secretos — NUNCA subir al repo
# -----------------------------------------------------------------------------
.env
.env.backup
.env.production

# -----------------------------------------------------------------------------
# Dependencias — se instalan con composer install
# -----------------------------------------------------------------------------
/vendor/

# -----------------------------------------------------------------------------
# Laravel — archivos generados en tiempo de ejecución
# -----------------------------------------------------------------------------
/bootstrap/cache/*.php
/storage/*.key

# Logs
/storage/logs/
*.log

# Cache de Laravel
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/testing/
/storage/framework/views/

# Swagger — se regenera con php artisan l5-swagger:generate
/storage/api-docs/

# -----------------------------------------------------------------------------
# Composer
# -----------------------------------------------------------------------------
composer.phar

# -----------------------------------------------------------------------------
# Node (si se añade frontend en el futuro)
# -----------------------------------------------------------------------------
/node_modules/
/public/build/
/public/hot/
npm-debug.log
yarn-error.log

# -----------------------------------------------------------------------------
# Docker — datos persistentes de los volúmenes
# -----------------------------------------------------------------------------
docker/mysql/

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Tests
# -----------------------------------------------------------------------------
/.phpunit.cache/
/coverage/