APP_NAME="Laravel API Blueprint"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de datos — coincidir con docker-compose.yml
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel_api
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# JWT — se genera con: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60

# Swagger
L5_SWAGGER_GENERATE_ALWAYS=true
